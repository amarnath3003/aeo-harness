# ─────────────────────────────────────────────────────────────────────────────
# AEO Research Harness — Backend Environment Variables
# Copy this file to backend/.env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Path to your GGUF model file.
# Recommended: gemma-3-1b-it-Q4_K_M.gguf  (best accuracy/size tradeoff for 1B)
# Alternative: gemma-3-1b-it-Q8_0.gguf    (higher quality, ~2× larger)
# Alternative: gemma-3-1b-it-IQ3_M.gguf   (very small, lower quality)
MODEL_PATH=./models/gemma-3-1b-it-Q4_K_M.gguf

# Number of model layers to offload to GPU.
# 0  = CPU-only (default, recommended for mobile edge simulation)
# 99 = offload all layers (fast, but bypasses edge device simulation)
GPU_LAYERS=0

# Express server port (frontend proxies to this)
PORT=3001

# llama.cpp context window size (tokens).
# 2048 is safe for 1B models on constrained RAM.
# Increase to 4096 if you have ≥8GB RAM.
CONTEXT_SIZE=2048

# Max concurrent benchmark runs (leave at 1 for reproducible results)
MAX_CONCURRENT=1

# Telemetry sample interval in milliseconds (default 500ms = 2 samples/sec)
TELEMETRY_INTERVAL_MS=500
